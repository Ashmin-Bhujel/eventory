{
  "name": "eventory",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "lint": "bun --bun eslint",
    "lint:fix": "bun --bun eslint --fix",
    "fmt": "bun --bun prettier --write .",
    "fmt:check": "bun --bun prettier --check .",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bun --bun eslint --fix",
      "bun --bun prettier --write"
    ],
    "*.{html,css,json,md}": [
      "bun --bun prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.2.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@imagekit/nodejs": "^7.5.0",
    "@imagekit/react": "^5.0.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-form-start": "^1.29.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.167.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "mongoose": "^9.6.1",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@latest",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/eslint-plugin-query": "^5.100.9",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "packageManager": "bun@1.3.13"
}
